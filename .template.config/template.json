{
  "$schema": "http://json.schemastore.org/template",
  "author": "James Balenthiran",
  "classifications": [ "Web", "Personal", "Monorepo" ],
  "name": "Personal Web Template",
  "identity": "Balenthiran.WebTemplate",
  "shortName": "web-template",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "SolutionName",
  "preferNameDirectory": true,
  "symbols": {
    "appName": {
      "type": "parameter",
      "datatype": "string",
      "description": "The name of the application for deployment setups.",
      "replaces": "your-app-name",
      "isRequired": true
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "include": [ ".github/**" ]
        },
        {
          "exclude": [
            "bin/**",
            "obj/**",
            "**/node_modules/**",
            "frontend/dist/**",
            "**/*.user",
            ".git/**"
          ]
        }
      ]
    }
  ]
}
